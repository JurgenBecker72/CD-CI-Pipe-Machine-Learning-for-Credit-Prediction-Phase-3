# Copy this file to .env and edit. .env is gitignored; .env.example is committed.
#
# All variables here are consumed by src/settings.py via pydantic-settings.
# Variable names are case-insensitive. Anything not declared in Settings is
# ignored, so it's safe to keep extra notes here.

# --- Environment ---------------------------------------------------------
# One of: local, dev, staging, production
ENV=local
LOG_LEVEL=INFO

# --- Reproducibility -----------------------------------------------------
RANDOM_SEED=42

# --- Filesystem (defaults derive from src/paths.py — usually no need to set)
# Override only if your data lives outside the project root, e.g. on a
# mounted volume in a container.
# RAW_DIR=/absolute/path/to/data/raw
# PROCESSED_DIR=/absolute/path/to/data/processed
# MODELS_DIR=/absolute/path/to/models
RAW_DATASET_FILENAME=DRA_with_simulated_credit.xlsx

# --- MLflow (Phase C) ----------------------------------------------------
# Local MLflow tracking server (started via docker-compose in Phase C).
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=credit-scorecard

# --- DuckDB warehouse (Phase B) ------------------------------------------
# DUCKDB_PATH=warehouse/credit.duckdb
